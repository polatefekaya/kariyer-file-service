# Build artifacts (keep the build context small + avoid stale local output)
**/bin/
**/obj/
**/out/
artifacts/

# Tests are not part of the runtime image
tests/

# VCS / editors
.git/
.gitignore
.vs/
.vscode/
.idea/
**/*.user

# Secrets / local env (never bake into the image)
.env
.env.*
!.env.example

# Docker + docs (not needed inside the build context)
Dockerfile
.dockerignore
docker-compose*.yml
**/*.md

# OS cruft
.DS_Store
Thumbs.db
