# Build artifacts (keep the build context small + avoid stale local output)
**/bin/
**/obj/
**/out/
artifacts/
# Editor's Roslyn BuildHost writes literal-backslash "bin\Debug"/"obj\Debug" dirs
# on macOS; ? matches the backslash so these never enter the build context.
**/bin?Debug
**/obj?Debug
**/bin?Release
**/obj?Release

# Tests are not part of the runtime image
tests/

# VCS / editors
.git/
.gitignore
.vs/
.vscode/
.idea/
**/*.user

# Secrets / local env (never bake into the image)
.env
.env.*
!.env.example

# Docker + docs (not needed inside the build context)
Dockerfile
.dockerignore
docker-compose*.yml
**/*.md

# OS cruft
.DS_Store
Thumbs.db
